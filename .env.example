# ── This app (billing subdomain) ─────────────────────────────────────────────
NEXT_PUBLIC_BILLING_URL=https://billing.citronos.com
# Main marketing/commerce site — where pricing, cart and checkout live.
NEXT_PUBLIC_SITE_URL=https://citronos.com

# ── Identity (auth — separate system) ────────────────────────────────────────
NEXT_PUBLIC_IDENTITY_URL=https://identity.citronos.com
IDENTITY_API_URL=
SESSION_COOKIE_NAME=citron_session
# Set to "1" in local dev to preview with a fake session.
DEV_FAKE_SESSION=

# ── Citron Platform API (citron-api) — the billing/usage source of truth ─────
CITRON_API_URL=
CITRON_API_TOKEN=

# ── Stripe (for the Customer Portal + credit top-ups) ────────────────────────
STRIPE_SECRET_KEY=sk_test_...
